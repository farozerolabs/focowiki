x-docker-logging: &docker-logging
  driver: json-file
  options:
    max-size: "50m"
    max-file: "3"

services:
  admin:
    image: ${FOCOWIKI_ADMIN_IMAGE:-ghcr.io/farozerolabs/focowiki-admin:latest}
    environment:
      ADMIN_API_PROXY_TARGET: ${ADMIN_API_PROXY_TARGET:?Set ADMIN_API_PROXY_TARGET in .env}
    ports:
      - "${ADMIN_UI_PORT:?Set ADMIN_UI_PORT in .env}:8080"
    depends_on:
      api:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "[ \"$(wget -qO- http://127.0.0.1:8080/healthz)\" = \"ok\" ]"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 10s
    logging: *docker-logging
    restart: unless-stopped

  api:
    image: ${FOCOWIKI_API_IMAGE:-ghcr.io/farozerolabs/focowiki-api:latest}
    env_file:
      - .env
    ports:
      - "${ADMIN_API_PORT:?Set ADMIN_API_PORT in .env}:${ADMIN_API_PORT:?Set ADMIN_API_PORT in .env}"
      - "${PUBLIC_OPENAPI_PORT:?Set PUBLIC_OPENAPI_PORT in .env}:${PUBLIC_OPENAPI_PORT:?Set PUBLIC_OPENAPI_PORT in .env}"
    volumes:
      - ./logs:/app/logs
      - ./runtime-secrets:/app/runtime-secrets
    depends_on:
      migrate:
        condition: service_completed_successfully
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "node -e \"const check=(port)=>fetch('http://127.0.0.1:'+port+'/healthz').then(async(r)=>{const body=await r.json().catch(()=>null);return r.ok&&body?.status==='ok';});const adminPort=process.env.ADMIN_API_PORT||'43000';const publicPort=process.env.PUBLIC_OPENAPI_PORT||'43200';Promise.all([check(adminPort),check(publicPort)]).then((checks)=>process.exit(checks.every(Boolean)?0:1)).catch(()=>process.exit(1));\""]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 20s
    logging: *docker-logging
    restart: unless-stopped

  source-worker:
    image: ${FOCOWIKI_API_IMAGE:-ghcr.io/farozerolabs/focowiki-api:latest}
    command: ["node", "apps/api/runtime/source-worker.mjs"]
    env_file:
      - .env
    volumes:
      - ./logs:/app/logs
      - ./runtime-secrets:/app/runtime-secrets
    depends_on:
      migrate:
        condition: service_completed_successfully
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "apps/api/runtime/source-worker.mjs", "--healthcheck"]
      interval: 15s
      timeout: 10s
      retries: 8
      start_period: 20s
    stop_grace_period: 30s
    logging: *docker-logging
    restart: unless-stopped

  publication-worker:
    image: ${FOCOWIKI_API_IMAGE:-ghcr.io/farozerolabs/focowiki-api:latest}
    command: ["node", "apps/api/runtime/publication-worker.mjs"]
    env_file:
      - .env
    volumes:
      - ./logs:/app/logs
      - ./runtime-secrets:/app/runtime-secrets
    depends_on:
      migrate:
        condition: service_completed_successfully
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "apps/api/runtime/publication-worker.mjs", "--healthcheck"]
      interval: 15s
      timeout: 10s
      retries: 8
      start_period: 20s
    stop_grace_period: 30s
    logging: *docker-logging
    restart: unless-stopped

  maintenance-worker:
    image: ${FOCOWIKI_API_IMAGE:-ghcr.io/farozerolabs/focowiki-api:latest}
    command: ["node", "apps/api/runtime/maintenance-worker.mjs"]
    env_file:
      - .env
    volumes:
      - ./logs:/app/logs
      - ./runtime-secrets:/app/runtime-secrets
    depends_on:
      migrate:
        condition: service_completed_successfully
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "apps/api/runtime/maintenance-worker.mjs", "--healthcheck"]
      interval: 30s
      timeout: 10s
      retries: 8
      start_period: 20s
    stop_grace_period: 30s
    logging: *docker-logging
    restart: unless-stopped

  migrate:
    image: ${FOCOWIKI_API_IMAGE:-ghcr.io/farozerolabs/focowiki-api:latest}
    command: ["node", "apps/api/runtime/migrate.mjs"]
    env_file:
      - .env
    volumes:
      - ./logs:/app/logs
      - ./runtime-secrets:/app/runtime-secrets
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    logging: *docker-logging
    restart: "no"

  postgres:
    image: postgres:18-alpine
    environment:
      POSTGRES_DB: ${POSTGRES_DB:?Set POSTGRES_DB in .env}
      POSTGRES_USER: ${POSTGRES_USER:?Set POSTGRES_USER in .env}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:?Set POSTGRES_PASSWORD in .env}
    volumes:
      - ./data/postgres:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:?Set POSTGRES_USER in .env} -d ${POSTGRES_DB:?Set POSTGRES_DB in .env}"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 10s
    logging: *docker-logging
    restart: unless-stopped

  redis:
    image: redis:8-alpine
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - ./data/redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 5s
    logging: *docker-logging
    restart: unless-stopped
