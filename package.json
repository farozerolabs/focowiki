{
  "name": "focowiki",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @focowiki/api --filter @focowiki/admin dev",
    "dev:api": "pnpm --filter @focowiki/api dev",
    "dev:admin": "pnpm --filter @focowiki/admin dev",
    "compose:config": "docker compose -f docker-compose.yml config",
    "compose:example:config": "docker compose --env-file .env.example -f docker-compose.yml.example config --no-env-resolution --quiet",
    "compose:pull": "docker compose -f docker-compose.yml pull",
    "compose:migrate": "docker compose -f docker-compose.yml run --rm migrate",
    "compose:up": "docker compose -f docker-compose.yml up -d",
    "compose:down": "docker compose -f docker-compose.yml down",
    "compose:clean": "docker compose -f docker-compose.yml down --volumes --remove-orphans --rmi all",
    "compose:logs": "docker compose -f docker-compose.yml logs -f",
    "compose:ps": "docker compose -f docker-compose.yml ps",
    "compose:dev:config": "docker compose -f docker-compose.dev.yml config",
    "compose:dev:example:config": "docker compose --env-file .env.dev.example -f docker-compose.dev.yml.example config --no-env-resolution --quiet",
    "compose:dev:build": "docker compose -f docker-compose.dev.yml build",
    "compose:dev:migrate": "docker compose -f docker-compose.dev.yml run --rm migrate",
    "compose:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "compose:dev:down": "docker compose -f docker-compose.dev.yml down",
    "compose:dev:clean": "docker compose -f docker-compose.dev.yml down --volumes --remove-orphans --rmi all",
    "compose:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "compose:dev:ps": "docker compose -f docker-compose.dev.yml ps",
    "compose:local:config": "docker compose -f docker-compose.local.yml config",
    "compose:local:example:config": "docker compose --env-file .env.dev.example -f docker-compose.local.yml.example config --no-env-resolution --quiet",
    "compose:local:up": "docker compose -f docker-compose.local.yml up -d postgres redis",
    "compose:local:down": "docker compose -f docker-compose.local.yml down",
    "compose:local:clean": "docker compose -f docker-compose.local.yml down --volumes --remove-orphans",
    "compose:local:ps": "docker compose -f docker-compose.local.yml ps",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "validate:cleaned-markdown:samples": "node scripts/validation/cleaned-markdown-flow.mjs samples",
    "validate:cleaned-markdown:api": "node scripts/validation/cleaned-markdown-flow.mjs api",
    "validate:cleaned-markdown:browser": "node scripts/validation/cleaned-markdown-browser.mjs",
    "validate:cleaned-legal:samples": "node scripts/validation/cleaned-markdown-flow.mjs samples",
    "validate:cleaned-legal:api": "node scripts/validation/cleaned-markdown-flow.mjs api",
    "validate:cleaned-legal:browser": "node scripts/validation/cleaned-markdown-browser.mjs",
    "validate:real-legal:samples": "node scripts/validation/cleaned-markdown-flow.mjs samples",
    "validate:real-legal:api": "node scripts/validation/cleaned-markdown-flow.mjs api",
    "validate:real-legal:browser": "node scripts/validation/cleaned-markdown-browser.mjs",
    "validate:real-legal:large:samples": "node scripts/validation/cleaned-markdown-flow.mjs large-samples",
    "validate:real-legal:large:api": "node scripts/validation/cleaned-markdown-flow.mjs large-api",
    "validate:real-legal:large:browser": "node scripts/validation/cleaned-markdown-browser.mjs large-browser",
    "validate:no-local-paths": "node scripts/validation/no-local-path-leaks.mjs",
    "openapi:export": "tsx scripts/openapi/export-developer-openapi.ts",
    "openapi:validate": "tsx scripts/openapi/validate-developer-openapi.ts",
    "test:validation": "node --test scripts/validation/test/*.test.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "2.33.2",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
