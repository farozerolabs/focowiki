# Admin API
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-this-session-secret
ADMIN_API_PORT=43000
ADMIN_API_PROXY_TARGET=http://127.0.0.1:43000

# Required infrastructure
DATABASE_URL=postgres://focowiki:focowiki@127.0.0.1:55432/focowiki
REDIS_URL=redis://127.0.0.1:56379/0

# Public OpenAPI file reads
PUBLIC_OPENAPI_PORT=43200
PUBLIC_BASE_URL=http://127.0.0.1:43200
PUBLIC_API_AUTH_REQUIRED=false
PUBLIC_API_KEY=
CORS_ORIGINS=http://127.0.0.1:43100

# Admin UI
ADMIN_UI_PORT=43100

# S3-compatible storage
S3_ENDPOINT=http://127.0.0.1:43300
S3_REGION=local
S3_BUCKET=focowiki
S3_ACCESS_KEY_ID=dev
S3_SECRET_ACCESS_KEY=dev
# Logical internal object-key namespace. This is not exposed in public URLs.
S3_PREFIX=dev
S3_FORCE_PATH_STYLE=true

# Upload limits
MAX_UPLOAD_BYTES=1048576
MAX_UPLOAD_FILES=24
GENERATION_BATCH_SIZE=50
UPLOAD_TASK_CONCURRENCY=1
UPLOAD_FILE_PROCESSING_CONCURRENCY=1

# Admin pagination
ADMIN_LIST_PAGE_SIZE=50
ADMIN_LIST_MAX_PAGE_SIZE=200
ADMIN_PAGINATION_CURSOR_TTL_SECONDS=900

# Optional OpenAI-compatible model assistance
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=
MODEL_NAME=
MODEL_CONTEXT_WINDOW_TOKENS=200000
MODEL_REQUEST_MAX_TIMEOUT_MS=120000
MODEL_REQUEST_IDLE_TIMEOUT_MS=30000
MODEL_SUGGESTION_CONCURRENCY=2
