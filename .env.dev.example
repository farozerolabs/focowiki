# Admin API
APP_ENV=development
LOG_LEVEL=debug

# Runtime log files
LOG_FILE_DIR=logs
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_MAX_FILES=5
# Docker Compose host path. Relative paths resolve from the directory that contains docker-compose.yml and .env.
LOG_FILE_HOST_DIR=./logs
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-this-session-secret
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_SESSION_SECRET_MIN_LENGTH=32
ADMIN_SESSION_COOKIE_SECURE=false
ADMIN_SESSION_COOKIE_SAME_SITE=Lax
ADMIN_API_PORT=43000
ADMIN_API_PROXY_TARGET=http://127.0.0.1:43000
ADMIN_PUBLIC_ORIGIN=http://localhost:43100
ADMIN_API_PUBLIC_ORIGIN=http://localhost:43000
ADMIN_TRUSTED_ORIGINS=http://localhost:43100,http://127.0.0.1:43100
ALLOWED_HOSTS=
TRUSTED_PROXY_MODE=false

# Required infrastructure
POSTGRES_DB=focowiki
POSTGRES_USER=focowiki
POSTGRES_PASSWORD=focowiki
POSTGRES_PORT=55432
DATABASE_URL=postgres://focowiki:focowiki@127.0.0.1:55432/focowiki
DATABASE_POOL_MAX=10
REDIS_PORT=56379
REDIS_URL=redis://127.0.0.1:56379/0

# Developer OpenAPI
PUBLIC_OPENAPI_PORT=43200
PUBLIC_BASE_URL=http://127.0.0.1:43200
PUBLIC_OPENAPI_PUBLIC_ORIGIN=http://localhost:43200
CORS_ORIGINS=http://127.0.0.1:43100,http://localhost:43100

# Admin UI
ADMIN_UI_HOST=0.0.0.0
ADMIN_UI_PORT=43100
VITE_ADMIN_API_BASE_URL=

# S3-compatible storage
S3_ENDPOINT=http://127.0.0.1:43300
S3_REGION=local
S3_BUCKET=focowiki
S3_ACCESS_KEY_ID=dev
S3_SECRET_ACCESS_KEY=dev
# Logical internal object-key namespace. This is not exposed in public URLs.
S3_PREFIX=dev
S3_FORCE_PATH_STYLE=true

# Upload limits
MAX_UPLOAD_BYTES=1048576
MAX_UPLOAD_FILES=24
GENERATION_BATCH_SIZE=50
UPLOAD_FILE_PROCESSING_CONCURRENCY=1
UPLOAD_STORAGE_CONCURRENCY=4
OKF_LOG_MAX_ENTRIES=100
OKF_LOG_MAX_BYTES=65536

# Pagination and content read limits
ADMIN_LIST_DEFAULT_PAGE_SIZE=50
ADMIN_LIST_MAX_PAGE_SIZE=200
TREE_CHILD_DEFAULT_PAGE_SIZE=100
TREE_CHILD_MAX_PAGE_SIZE=500
PAGINATION_CURSOR_TTL_SECONDS=900
GENERATED_CONTENT_MAX_BYTES=10485760

# Worker queue settings
WORKER_DATABASE_POOL_MAX=6
WORKER_SOURCE_FILE_CONCURRENCY=2
WORKER_CLAIM_BATCH_SIZE=10
WORKER_POLL_INTERVAL_MS=1000
WORKER_LOCK_TTL_SECONDS=900
WORKER_HEARTBEAT_INTERVAL_MS=15000
WORKER_JOB_MAX_ATTEMPTS=3
WORKER_JOB_RETRY_DELAY_MS=30000
WORKER_QUEUE_BACKPRESSURE_LIMIT=5000
WORKER_QUEUE_BACKPRESSURE_KB_LIMIT=2000
WORKER_QUEUE_BACKPRESSURE_MAX_AGE_SECONDS=3600
WORKER_QUEUE_BACKPRESSURE_RETRY_AFTER_SECONDS=60
WORKER_SHUTDOWN_GRACE_MS=30000
WORKER_COMPLETED_JOB_RETENTION_DAYS=7
WORKER_FAILED_JOB_RETENTION_DAYS=30
WORKER_DEAD_LETTER_JOB_RETENTION_DAYS=90
WORKER_RETENTION_CLEANUP_BATCH_SIZE=1000

# Publication settings
PUBLICATION_MODE=batch
PUBLICATION_BATCH_SIZE=300
PUBLICATION_INTERVAL_SECONDS=300
INDEX_SHARD_SIZE=1000
LINK_INDEX_SHARD_SIZE=1000
MANIFEST_SHARD_SIZE=1000
GRAPH_EDGE_SHARD_SIZE=5000
GRAPH_CANDIDATE_LIMIT=200
GRAPH_MAINTENANCE_BATCH_SIZE=500
ROOT_SUMMARY_LIMIT=500

# Security limits
ADMIN_LOGIN_RATE_LIMIT_MAX=8
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
ADMIN_API_RATE_LIMIT_MAX=600
ADMIN_API_RATE_LIMIT_WINDOW_SECONDS=60
UPLOAD_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=3600
PUBLIC_OPENAPI_RATE_LIMIT_MAX=1200
PUBLIC_OPENAPI_RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_AUDIT_RETENTION_DAYS=30

# Optional OpenAI-compatible model assistance
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=
MODEL_NAME=
MODEL_CONTEXT_WINDOW_TOKENS=200000
MODEL_REQUEST_MAX_TIMEOUT_MS=600000
MODEL_REQUEST_IDLE_TIMEOUT_MS=120000
MODEL_TRANSIENT_RETRY_DELAY_MS=60000
MODEL_REQUEST_MIN_INTERVAL_MS=2000
MODEL_SUGGESTION_CONCURRENCY=2
